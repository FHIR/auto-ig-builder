#!/bin/bash

set -euo pipefail

attempts="${PUBLISH_ATTEMPTS:-4}"
base_delay_seconds="${PUBLISH_BASE_DELAY_SECONDS:-2}"
max_jitter_seconds="${PUBLISH_MAX_JITTER_SECONDS:-2}"

if [ "$attempts" -lt 1 ]; then
    echo "PUBLISH_ATTEMPTS must be >= 1" >&2
    exit 2
fi

attempt=1
while true; do
    echo "Starting publish attempt ${attempt}/${attempts} for $* from $(pwd)"
    if tar czf - * | ssh ci-build ./publish-ig "$@"; then
        echo "Publish completed on attempt ${attempt}/${attempts}"
        exit 0
    else
        status=$?
    fi
    if [ "$attempt" -ge "$attempts" ]; then
        echo "Publish failed after ${attempt}/${attempts} attempts with exit status ${status}" >&2
        exit "$status"
    fi

    backoff_seconds=$((base_delay_seconds << (attempt - 1)))
    jitter_seconds=0
    if [ "$max_jitter_seconds" -gt 0 ]; then
        jitter_seconds=$((RANDOM % (max_jitter_seconds + 1)))
    fi
    sleep_seconds=$((backoff_seconds + jitter_seconds))

    echo "Publish attempt ${attempt}/${attempts} failed with exit status ${status}; retrying in ${sleep_seconds}s" >&2
    sleep "$sleep_seconds"
    attempt=$((attempt + 1))
done
